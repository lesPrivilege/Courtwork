{
  "name": "@courtwork/desktop",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 127.0.0.1",
    "test": "vitest run",
    "test:e2e": "node scripts/assert-motion-properties.mjs && node scripts/assert-signature-line.mjs && node scripts/assert-graph-theme.mjs && node scripts/verify-icons.mjs && node scripts/assert-preview-boundaries.mjs && node scripts/assert-elevation-shadow.mjs && node scripts/assert-rp26-contracts.mjs && node scripts/assert-rp27-contracts.mjs && node scripts/assert-thinking-stream.mjs && node scripts/assert-rp28-contracts.mjs && node scripts/assert-rp29-contracts.mjs && node scripts/assert-rp291-contracts.mjs && node scripts/assert-test-count.mjs && playwright test",
    "test:e2e:list": "playwright test --list",
    "lint:motion": "node scripts/assert-motion-properties.mjs",
    "lint:signature": "node scripts/assert-signature-line.mjs",
    "lint:graph": "node scripts/assert-graph-theme.mjs",
    "lint:icons": "node scripts/verify-icons.mjs",
    "lint:preview": "node scripts/assert-preview-boundaries.mjs",
    "lint:elevation": "node scripts/assert-elevation-shadow.mjs",
    "lint:rp26": "node scripts/assert-rp26-contracts.mjs",
    "lint:rp27": "node scripts/assert-rp27-contracts.mjs",
    "lint:thinking": "node scripts/assert-thinking-stream.mjs",
    "lint:rp28": "node scripts/assert-rp28-contracts.mjs",
    "lint:rp29": "node scripts/assert-rp29-contracts.mjs",
    "lint:rp291": "node scripts/assert-rp291-contracts.mjs",
    "icons:optimize": "svgo --folder src/icons/custom --config svgo.config.mjs",
    "icons:generate": "node scripts/generate-custom-icons.mjs",
    "icons:build": "pnpm icons:optimize && pnpm icons:generate && pnpm lint:icons",
    "visual:audit": "node scripts/capture-visual-audit.mjs",
    "tauri": "tauri"
  },
  "dependencies": {
    "@antv/g6": "^5.1.1",
    "@courtwork/core": "workspace:*",
    "@courtwork/reading-view": "workspace:*",
    "@courtwork/schemas": "workspace:*",
    "@courtwork/tools": "workspace:^",
    "@tauri-apps/api": "^2.8.0",
    "@tauri-apps/plugin-opener": "^2",
    "lucide-react": "^1.24.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "@tauri-apps/cli": "^2.8.4",
    "@types/react": "^19.1.12",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.2",
    "svgo": "^4.0.1",
    "vite": "^7.1.5"
  }
}
