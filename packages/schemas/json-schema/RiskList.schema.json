{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "caseId": {
      "type": "string",
      "minLength": 1
    },
    "risks": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "level": {
            "type": "string",
            "enum": [
              "high",
              "medium",
              "low"
            ]
          },
          "basis": {
            "minItems": 1,
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "citation": {
                  "type": "string",
                  "minLength": 1
                },
                "sourceAnchors": {
                  "minItems": 1,
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "fileId": {
                        "type": "string",
                        "minLength": 1
                      },
                      "page": {
                        "type": "integer",
                        "exclusiveMinimum": 0,
                        "maximum": 9007199254740991
                      },
                      "bbox": {
                        "type": "object",
                        "properties": {
                          "x": {
                            "type": "number"
                          },
                          "y": {
                            "type": "number"
                          },
                          "width": {
                            "type": "number",
                            "exclusiveMinimum": 0
                          },
                          "height": {
                            "type": "number",
                            "exclusiveMinimum": 0
                          }
                        },
                        "required": [
                          "x",
                          "y",
                          "width",
                          "height"
                        ],
                        "additionalProperties": false
                      },
                      "textRange": {
                        "type": "object",
                        "properties": {
                          "start": {
                            "type": "integer",
                            "minimum": 0,
                            "maximum": 9007199254740991
                          },
                          "end": {
                            "type": "integer",
                            "minimum": 0,
                            "maximum": 9007199254740991
                          }
                        },
                        "required": [
                          "start",
                          "end"
                        ],
                        "additionalProperties": false
                      },
                      "textLayerVersion": {
                        "type": "string"
                      },
                      "quote": {
                        "type": "string"
                      }
                    },
                    "required": [
                      "fileId"
                    ],
                    "additionalProperties": false,
                    "title": "SourceAnchor",
                    "description": "来源引用锚：一切可溯源交互的地基。定位到具体文件的页面坐标区域（bbox）和/或文本层字符区间（textRange）。quote 仅作展示与重锚定辅助，不是权威定位器。"
                  }
                }
              },
              "required": [
                "citation",
                "sourceAnchors"
              ],
              "additionalProperties": false
            }
          },
          "dispositionStatus": {
            "type": "string",
            "enum": [
              "pending",
              "confirmed",
              "rejected"
            ]
          }
        },
        "required": [
          "id",
          "description",
          "level",
          "basis",
          "dispositionStatus"
        ],
        "additionalProperties": false
      }
    }
  },
  "required": [
    "caseId",
    "risks"
  ],
  "additionalProperties": false,
  "title": "RiskList",
  "description": "风险清单：风险点 + 等级 + 依据（法条/判例引用 + 来源锚点）+ 处置状态。"
}
