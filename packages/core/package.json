{
  "name": "@courtwork/core",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./provider-quirks": {
      "types": "./dist/provider-compat/provider-quirks.d.ts",
      "default": "./dist/provider-compat/provider-quirks.js"
    },
    "./provider-openai": {
      "types": "./dist/provider-compat/provider-openai.d.ts",
      "default": "./dist/provider-compat/provider-openai.js"
    },
    "./provider-types": {
      "types": "./dist/provider-compat/provider-types.d.ts",
      "default": "./dist/provider-compat/provider-types.js"
    },
    "./generic-chat": {
      "types": "./dist/assembly/generic-chat.d.ts",
      "default": "./dist/assembly/generic-chat.js"
    },
    "./turn-protocol": {
      "types": "./dist/turn/turn-protocol.d.ts",
      "default": "./dist/turn/turn-protocol.js"
    },
    "./turn-store-file": {
      "types": "./dist/turn/turn-store-file.d.ts",
      "default": "./dist/turn/turn-store-file.js"
    },
    "./work-protocol": {
      "types": "./dist/work/work-protocol.d.ts",
      "default": "./dist/work/work-protocol.js"
    },
    "./work-store-file": {
      "types": "./dist/work/work-store-file.d.ts",
      "default": "./dist/work/work-store-file.js"
    }
  },
  "courtwork": {
    "deprecatedExports": {
      "./provider-quirks": "@courtwork/provider/quirks",
      "./provider-openai": "@courtwork/provider/openai",
      "./provider-types": "@courtwork/provider/types"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run --root ../.. packages/core",
    "lint": "eslint .",
    "smoke:provider": "tsx scripts/smoke-provider.ts"
  },
  "dependencies": {
    "@courtwork/provider": "workspace:*",
    "@courtwork/schemas": "workspace:*",
    "@courtwork/registry": "workspace:*",
    "@courtwork/tools": "workspace:*",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.1"
  }
}
