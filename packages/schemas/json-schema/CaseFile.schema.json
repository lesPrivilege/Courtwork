{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "caseId": {
      "type": "string",
      "minLength": 1
    },
    "files": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "fileId": {
            "type": "string",
            "minLength": 1
          },
          "fileName": {
            "type": "string",
            "minLength": 1
          },
          "documentType": {
            "type": "string",
            "minLength": 1
          },
          "ingestStatus": {
            "type": "string",
            "enum": [
              "pending",
              "processing",
              "done",
              "failed"
            ]
          },
          "pageCount": {
            "type": "integer",
            "exclusiveMinimum": 0,
            "maximum": 9007199254740991
          }
        },
        "required": [
          "fileId",
          "fileName",
          "documentType",
          "ingestStatus"
        ],
        "additionalProperties": false
      }
    }
  },
  "required": [
    "caseId",
    "files"
  ],
  "additionalProperties": false,
  "title": "CaseFile",
  "description": "案件档案：卷内文件清单、文书类型分类、摄取状态。"
}
