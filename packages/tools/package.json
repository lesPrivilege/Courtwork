{
  "name": "@courtwork/tools",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./case-path": {
      "types": "./dist/case-path.d.ts",
      "default": "./dist/case-path.js"
    },
    "./system-open": {
      "types": "./dist/system-open.d.ts",
      "default": "./dist/system-open.js"
    },
    "./contract": {
      "types": "./dist/contract.d.ts",
      "default": "./dist/contract.js"
    },
    "./file-ops-host": {
      "types": "./dist/file-ops-host.d.ts",
      "default": "./dist/file-ops-host.js"
    },
    "./file-ops-lossless": {
      "types": "./dist/file-ops-lossless.d.ts",
      "default": "./dist/file-ops-lossless.js"
    },
    "./file-ops-executor": {
      "types": "./dist/file-ops-executor.d.ts",
      "default": "./dist/file-ops-executor.js"
    }
  },
  "scripts": {
    "test": "vitest run --root ../.. src/*.test.ts",
    "lint": "eslint .",
    "build": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "@courtwork/schemas": "workspace:*",
    "@mozilla/readability": "^0.6.0",
    "jsdom": "^29.1.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@courtwork/demo-data": "workspace:*",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^26.1.1"
  }
}
