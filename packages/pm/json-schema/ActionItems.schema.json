{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "properties": {
    "projectId": {
      "type": "string",
      "minLength": 1
    },
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "action": {
            "type": "string",
            "minLength": 1
          },
          "owner": {
            "anyOf": [
              {
                "type": "string",
                "minLength": 1
              },
              {
                "type": "null"
              }
            ]
          },
          "due": {
            "anyOf": [
              {
                "type": "string",
                "format": "date",
                "pattern": "^(?:(?:\\d\\d[2468][048]|\\d\\d[13579][26]|\\d\\d0[48]|[02468][048]00|[13579][26]00)-02-29|\\d{4}-(?:(?:0[13578]|1[02])-(?:0[1-9]|[12]\\d|3[01])|(?:0[469]|11)-(?:0[1-9]|[12]\\d|30)|(?:02)-(?:0[1-9]|1\\d|2[0-8])))$"
              },
              {
                "type": "null"
              }
            ]
          },
          "sourceAnchors": {
            "minItems": 1,
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "fileId": {
                  "type": "string",
                  "minLength": 1
                },
                "page": {
                  "type": "integer",
                  "exclusiveMinimum": 0,
                  "maximum": 9007199254740991
                },
                "bbox": {
                  "type": "object",
                  "properties": {
                    "x": {
                      "type": "number"
                    },
                    "y": {
                      "type": "number"
                    },
                    "width": {
                      "type": "number",
                      "exclusiveMinimum": 0
                    },
                    "height": {
                      "type": "number",
                      "exclusiveMinimum": 0
                    }
                  },
                  "required": [
                    "x",
                    "y",
                    "width",
                    "height"
                  ],
                  "additionalProperties": false
                },
                "textRange": {
                  "type": "object",
                  "properties": {
                    "start": {
                      "type": "integer",
                      "minimum": 0,
                      "maximum": 9007199254740991
                    },
                    "end": {
                      "type": "integer",
                      "minimum": 0,
                      "maximum": 9007199254740991
                    }
                  },
                  "required": [
                    "start",
                    "end"
                  ],
                  "additionalProperties": false,
                  "description": "文本层字符区间；end 必须大于或等于 start，允许 start === end 的零长区间。",
                  "x-courtwork-invariant": "end >= start"
                },
                "textLayerVersion": {
                  "type": "string"
                },
                "quote": {
                  "type": "string"
                }
              },
              "required": [
                "fileId"
              ],
              "additionalProperties": false,
              "title": "SourceAnchor",
              "description": "来源引用锚：一切可溯源交互的地基。定位到具体文件的页面坐标区域（bbox）和/或文本层字符区间（textRange）。quote 仅作展示与重锚定辅助，不是权威定位器。"
            }
          },
          "markers": {
            "default": [],
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "unclosed",
                "reassigned"
              ]
            }
          },
          "carryOvers": {
            "default": [],
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "minutesRef": {
                  "type": "string",
                  "minLength": 1
                },
                "owner": {
                  "anyOf": [
                    {
                      "type": "string",
                      "minLength": 1
                    },
                    {
                      "type": "null"
                    }
                  ]
                },
                "sourceAnchors": {
                  "minItems": 1,
                  "type": "array",
                  "items": {
                    "type": "object",
                    "properties": {
                      "fileId": {
                        "type": "string",
                        "minLength": 1
                      },
                      "page": {
                        "type": "integer",
                        "exclusiveMinimum": 0,
                        "maximum": 9007199254740991
                      },
                      "bbox": {
                        "type": "object",
                        "properties": {
                          "x": {
                            "type": "number"
                          },
                          "y": {
                            "type": "number"
                          },
                          "width": {
                            "type": "number",
                            "exclusiveMinimum": 0
                          },
                          "height": {
                            "type": "number",
                            "exclusiveMinimum": 0
                          }
                        },
                        "required": [
                          "x",
                          "y",
                          "width",
                          "height"
                        ],
                        "additionalProperties": false
                      },
                      "textRange": {
                        "type": "object",
                        "properties": {
                          "start": {
                            "type": "integer",
                            "minimum": 0,
                            "maximum": 9007199254740991
                          },
                          "end": {
                            "type": "integer",
                            "minimum": 0,
                            "maximum": 9007199254740991
                          }
                        },
                        "required": [
                          "start",
                          "end"
                        ],
                        "additionalProperties": false,
                        "description": "文本层字符区间；end 必须大于或等于 start，允许 start === end 的零长区间。",
                        "x-courtwork-invariant": "end >= start"
                      },
                      "textLayerVersion": {
                        "type": "string"
                      },
                      "quote": {
                        "type": "string"
                      }
                    },
                    "required": [
                      "fileId"
                    ],
                    "additionalProperties": false,
                    "title": "SourceAnchor",
                    "description": "来源引用锚：一切可溯源交互的地基。定位到具体文件的页面坐标区域（bbox）和/或文本层字符区间（textRange）。quote 仅作展示与重锚定辅助，不是权威定位器。"
                  }
                }
              },
              "required": [
                "minutesRef",
                "owner",
                "sourceAnchors"
              ],
              "additionalProperties": false
            }
          },
          "status": {
            "type": "string",
            "enum": [
              "open",
              "done",
              "out_of_coverage"
            ]
          }
        },
        "required": [
          "id",
          "action",
          "owner",
          "due",
          "sourceAnchors",
          "markers",
          "carryOvers",
          "status"
        ],
        "additionalProperties": false
      }
    }
  },
  "required": [
    "projectId",
    "items"
  ],
  "additionalProperties": false,
  "title": "pm.ActionItems",
  "description": "PM-4 纪要行动项：谁/做什么/何时（各带锚）+ 跨纪要闭环核对（unclosed/reassigned）+ carryOvers 接续轨迹。负责人与截止日永为提案。",
  "$id": "urn:courtwork:schema:pm.ActionItems:v1"
}
