{
  "name": "@courtwork/core",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./provider-quirks": {
      "types": "./dist/provider/quirk-profile.d.ts",
      "default": "./dist/provider/quirk-profile.js"
    },
    "./provider-openai": {
      "types": "./dist/provider/openai-compatible-provider.d.ts",
      "default": "./dist/provider/openai-compatible-provider.js"
    },
    "./provider-types": {
      "types": "./dist/provider/types.d.ts",
      "default": "./dist/provider/types.js"
    },
    "./generic-chat": {
      "types": "./dist/assembly/generic-chat.d.ts",
      "default": "./dist/assembly/generic-chat.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run --root ../.. packages/core",
    "lint": "eslint .",
    "demo:s3": "tsx scripts/demo-s3-flow.ts",
    "smoke:provider": "tsx scripts/smoke-provider.ts",
    "real:s3": "tsx scripts/real-s3-run.ts"
  },
  "dependencies": {
    "@courtwork/schemas": "workspace:*",
    "@courtwork/registry": "workspace:*",
    "@courtwork/tools": "workspace:*",
    "@courtwork/output": "workspace:*",
    "@courtwork/demo-data": "workspace:*",
    "@courtwork/legal": "workspace:*",
    "@courtwork/reading-view": "workspace:*",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.1"
  }
}
