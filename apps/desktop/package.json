    "tauri": "tauri"
  },
  "dependencies": {
    "@courtwork/core": "workspace:*",
    "@courtwork/schemas": "workspace:*",
    "@tauri-apps/api": "^2.8.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "@tauri-apps/cli": "^2.8.4",
    "@types/react": "^19.1.12",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.2",
    "vite": "^7.1.5"
  }
}
